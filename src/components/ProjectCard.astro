---
import Icon from "./Icon.astro";

type Project = {
  name: string;
  repo: string;
  url: string;
  description: string;
  readmeExcerpt?: string;
  language?: string;
  technologies?: string[];
  updatedAt?: string;
  stars?: number;
};

const { project } = Astro.props as { project: Project };

const formattedDate = project.updatedAt
  ? new Intl.DateTimeFormat("es", { month: "short", year: "numeric" }).format(new Date(project.updatedAt))
  : "";
---

<article class="group flex h-full flex-col rounded-lg border border-[var(--border)] bg-[var(--panel)] p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-slate-300 hover:shadow-subtle">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="text-xs font-semibold uppercase tracking-wide text-[var(--muted)]">{project.repo}</p>
      <h3 class="mt-2 text-xl font-semibold leading-tight text-slate-950">
        <a class="inline-flex items-center gap-2 hover:text-[var(--accent)]" href={project.url} target="_blank" rel="noreferrer">
          <span>{project.name}</span>
          <Icon name="arrow" class="h-4 w-4 opacity-0 transition group-hover:translate-x-1 group-hover:opacity-100" />
        </a>
      </h3>
    </div>
    <a class="grid h-10 w-10 shrink-0 place-items-center rounded-md border border-[var(--border)] text-[var(--muted)] transition hover:border-[var(--accent)] hover:text-[var(--accent)]" href={project.url} target="_blank" rel="noreferrer" aria-label={`Abrir ${project.name} en GitHub`}>
      <Icon name="github" class="h-5 w-5" />
    </a>
  </div>

  <p class="mt-4 text-sm leading-6 text-[var(--muted)]">{project.description}</p>

  {project.readmeExcerpt && (
    <p class="mt-3 rounded-md border border-slate-200 bg-slate-50 px-3 py-2 text-sm leading-6 text-slate-600">
      {project.readmeExcerpt}
    </p>
  )}

  <div class="mt-5 flex flex-wrap gap-2">
    {project.language && <span class="rounded-md bg-slate-900 px-2.5 py-1 text-xs font-medium text-white">{project.language}</span>}
    {project.technologies?.map((tech) => (
      <span class="rounded-md border border-slate-200 bg-white px-2.5 py-1 text-xs font-medium text-slate-600">{tech}</span>
    ))}
  </div>

  <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-2 pt-6 text-xs font-medium text-[var(--muted)]">
    {formattedDate && (
      <span class="inline-flex items-center gap-1.5">
        <Icon name="clock" class="h-3.5 w-3.5" />
        Actualizado {formattedDate}
      </span>
    )}
    {typeof project.stars === "number" && (
      <span class="inline-flex items-center gap-1.5">
        <Icon name="star" class="h-3.5 w-3.5 text-amber-500" />
        {project.stars} estrellas
      </span>
    )}
  </div>
</article>
